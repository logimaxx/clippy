{
  "name": "webklip",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "jsx": {
    "importSource": "hono/jsx"
  },
  "scripts": {
    "dev": "WEBKLIP_DEV=1 bun run scripts/build-assets.ts --dev && bun run scripts/build-static.ts && WEBKLIP_DEV=1 bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build:assets": "bun run scripts/build-assets.ts",
    "build:static": "bun run scripts/build-static.ts",
    "build": "bun run build:assets && bun run build:static",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "cli": "bun run src/cli.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "marked": "^18.0.5",
    "uqr": "^0.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@playwright/test": "^1.51.0",
    "@types/bun": "^1.2.0",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2"
  }
}
