DATA_DIR=/data
PORT=3000
NODE_ENV=production
MAX_FILE_SIZE_MB=10

# Per-IP rate limits (rolling 1-hour window; IP from X-Forwarded-For / X-Real-IP)
RATE_LIMIT_CLIPS_PER_HOUR=30  # clip creation: POST /api/v1/clips/:slug
RATE_LIMIT_API_PER_HOUR=200   # all /api/* requests (includes clip creation)
CLEANUP_INTERVAL_MS=60000
SESSION_SECRET=change-me-generate-with-openssl-rand-base64-32
SECURE_COOKIES=true
CONTACT_EMAIL=security@example.com
ENABLE_AUTH_API=false
# Umami analytics (optional)
# UMAMI_WEBSITE_ID=your-website-id
# UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
# Or set UMAMI_URL=https://cloud.umami.is (script URL is derived)
# CSP_SCRIPT_HASHES=sha256-example...  # optional extra inline script hashes
# CORS_ORIGIN=https://your-frontend.example.com
