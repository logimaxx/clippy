{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "types": ["bun"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "rootDir": ".",
    "noEmit": true
  },
  "include": ["src/**/*", "scripts/**/*"]
}
